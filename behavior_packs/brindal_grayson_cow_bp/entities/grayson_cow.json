{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "bgcow:grayson_cow",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "bgcow:baby": {
        "minecraft:is_baby": {},
        "minecraft:scale": { "value": 0.5 },
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": "wheat",
          "grow_up": {
            "event": "bgcow:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 6,
          "speed_multiplier": 1.1
        }
      },
      "bgcow:adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/cow.json"
        },
        "minecraft:behavior.breed": {
          "priority": 3,
          "speed_multiplier": 1.0
        },
        "minecraft:breedable": {
          "require_tame": false,
          "breed_items": ["wheat"],
          "breeds_with": {
            "bgcow:brindal_cow": {},
            "bgcow:grayson_cow": {}
          }
        },
        "minecraft:interact": {
          "interactions": [
            {
              "on_interact": {
                "filters": {
                  "all_of": [
                    { "test": "is_family", "subject": "other", "value": "player" },
                    { "test": "has_equipment", "domain": "hand", "subject": "other", "value": "bucket:0" }
                  ]
                }
              },
              "use_item": true,
              "swing": true,
              "transform_to_item": "bucket:1",
              "play_sounds": "milk",
              "interact_text": "action.interact.milk"
            }
          ]
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["cow", "mob", "grayson_cow"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:nameable": {
        "always_show": true
      },
      "minecraft:health": { "value": 10, "max": 10 },
      "minecraft:movement": { "value": 0.25 },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:collision_box": { "width": 0.9, "height": 1.3 },
      "minecraft:physics": {},
      "minecraft:pushable": {},
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.panic": { "priority": 1, "speed_multiplier": 1.25 },
      "minecraft:behavior.tempt": {
        "priority": 4,
        "speed_multiplier": 1.25,
        "items": ["wheat"]
      },
      "minecraft:behavior.random_stroll": { "priority": 6, "speed_multiplier": 0.8 },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": { "priority": 9 }
    },
    "events": {
      "minecraft:entity_spawned": {
        "randomize": [
          { "weight": 95, "trigger": "bgcow:spawn_adult" },
          { "weight": 5, "add": { "component_groups": ["bgcow:baby"] } }
        ]
      },
      "minecraft:entity_born": {
        "add": { "component_groups": ["bgcow:baby"] }
      },
      "bgcow:spawn_adult": {
        "add": { "component_groups": ["bgcow:adult"] }
      },
      "bgcow:ageable_grow_up": {
        "remove": { "component_groups": ["bgcow:baby"] },
        "add": { "component_groups": ["bgcow:adult"] }
      }
    }
  }
}
